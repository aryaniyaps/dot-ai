import dynamic from 'next/dynamic';

// Lazy load shader components
const Scanlines = dynamic(() => import('./3d/shaders/Scanlines'));
const Particles = dynamic(() => import('./3d/shaders/Particles'));

function ArcReactor() {
  return (
    <mesh position={[0, 0, 0]}>
      <sphereGeometry args={[1, 32, 32]} />
      <meshStandardMaterial
        color="#00D4FF"
        emissive="#00D4FF"
        emissiveIntensity={2}
        toneMapped={false}
      />
      <pointLight color="#00D4FF" intensity={5} distance={20} />
    </mesh>
  );
}

function Scene() {
  return (
    <>
      <OrbitControls enableZoom={false} enablePan={false} />
      <ambientLight intensity={0.5} />
      <ArcReactor />
      <Stars radius={100} depth={50} count={5000} factor={4} saturation={0} fade speed={1} />
      <Particles />
      <EffectComposer>
        <Bloom luminanceThreshold={0.8} luminanceSmoothing={0.9} height={300} intensity={1.2} />
      </EffectComposer>
    </>
  );
}

