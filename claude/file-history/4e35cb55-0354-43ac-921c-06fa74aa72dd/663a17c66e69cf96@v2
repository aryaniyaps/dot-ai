<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Proctoring Room - CS101 Final Exam</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      background: #0f172a;
      color: white;
      padding: 0;
      line-height: 1.5;
      overflow: hidden;
    }

    .room-container {
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* Top Bar */
    .top-bar {
      background: #1e293b;
      border-bottom: 1px solid #334155;
      padding: 12px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .room-info {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .room-title {
      font-size: 18px;
      font-weight: 600;
      color: #f1f5f9;
    }

    .room-meta {
      display: flex;
      gap: 20px;
      font-size: 13px;
      color: #94a3b8;
    }

    .room-meta-item {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .room-meta-item .value {
      color: #f1f5f9;
      font-weight: 600;
    }

    .room-actions {
      display: flex;
      gap: 12px;
    }

    .btn {
      background: #334155;
      color: #f1f5f9;
      border: none;
      padding: 8px 16px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s;
    }

    .btn:hover {
      background: #475569;
    }

    .btn-primary {
      background: #3b82f6;
    }

    .btn-primary:hover {
      background: #2563eb;
    }

    .btn-danger {
      background: #dc2626;
    }

    .btn-danger:hover {
      background: #b91c1c;
    }

    /* Main Content */
    .main-content {
      flex: 1;
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: 0;
      overflow: hidden;
    }

    /* Video Grid */
    .video-grid-section {
      padding: 16px;
      overflow-y: auto;
      background: #0f172a;
    }

    .video-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 12px;
    }

    .video-card {
      background: #1e293b;
      border: 2px solid #334155;
      border-radius: 8px;
      overflow: hidden;
      position: relative;
    }

    .video-card.violation {
      border-color: #dc2626;
      box-shadow: 0 0 20px rgba(220, 38, 38, 0.5);
      animation: pulse-border 2s infinite;
    }

    @keyframes pulse-border {
      0%, 100% {
        border-color: #dc2626;
        box-shadow: 0 0 20px rgba(220, 38, 38, 0.5);
      }
      50% {
        border-color: #ef4444;
        box-shadow: 0 0 30px rgba(220, 38, 38, 0.8);
      }
    }

    .video-card.selected {
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3);
    }

    .video-feed {
      width: 100%;
      height: 200px;
      background: #0f172a;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .video-feed-placeholder {
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .video-feed-placeholder svg {
      width: 48px;
      height: 48px;
      color: #475569;
    }

    .video-feed-placeholder span {
      font-size: 12px;
      color: #64748b;
    }

    .video-overlay {
      position: absolute;
      top: 8px;
      left: 8px;
      right: 8px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      pointer-events: none;
    }

    .student-badge {
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(8px);
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 600;
      color: #f1f5f9;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .violation-badge {
      background: rgba(220, 38, 38, 0.9);
      backdrop-filter: blur(8px);
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      color: white;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .audio-indicator {
      position: absolute;
      bottom: 8px;
      left: 8px;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(8px);
      padding: 4px 8px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      color: #94a3b8;
    }

    .audio-indicator.speaking {
      color: #22c55e;
    }

    .audio-indicator.speaking .audio-icon {
      animation: speaking 0.5s infinite;
    }

    @keyframes speaking {
      0%, 100% { transform: scaleY(1); }
      50% { transform: scaleY(1.5); }
    }

    .audio-bars {
      display: flex;
      gap: 2px;
      align-items: flex-end;
      height: 14px;
    }

    .audio-bar {
      width: 3px;
      background: currentColor;
      border-radius: 2px;
      animation: audio-wave 0.8s infinite ease-in-out;
    }

    .audio-bar:nth-child(1) { animation-delay: 0s; height: 6px; }
    .audio-bar:nth-child(2) { animation-delay: 0.1s; height: 10px; }
    .audio-bar:nth-child(3) { animation-delay: 0.2s; height: 8px; }
    .audio-bar:nth-child(4) { animation-delay: 0.3s; height: 12px; }
    .audio-bar:nth-child(5) { animation-delay: 0.4s; height: 6px; }

    @keyframes audio-wave {
      0%, 100% { transform: scaleY(1); }
      50% { transform: scaleY(1.8); }
    }

    .audio-indicator.muted .audio-bar {
      animation: none;
      height: 3px;
      background: #64748b;
    }

    .card-info {
      padding: 10px 12px;
      background: #1e293b;
      border-top: 1px solid #334155;
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }

    .student-name {
      font-size: 13px;
      font-weight: 600;
      color: #f1f5f9;
    }

    .exam-status {
      font-size: 11px;
      color: #22c55e;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .exam-status.problem {
      color: #fbbf24;
    }

    .card-meta {
      font-size: 11px;
      color: #64748b;
      display: flex;
      gap: 12px;
      margin-bottom: 8px;
    }

    .card-actions {
      display: flex;
      gap: 6px;
      padding-top: 8px;
      border-top: 1px solid #334155;
    }

    .action-btn {
      flex: 1;
      background: #334155;
      border: none;
      color: #e2e8f0;
      padding: 6px 8px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
    }

    .action-btn:hover {
      background: #475569;
    }

    .action-btn.warn {
      background: #f59e0b;
      color: #1e293b;
    }

    .action-btn.warn:hover {
      background: #fbbf24;
    }

    .action-btn.kick {
      background: #dc2626;
      color: white;
    }

    .action-btn.kick:hover {
      background: #ef4444;
    }

    .action-btn.screenshot {
      background: #3b82f6;
      color: white;
    }

    .action-btn.screenshot:hover {
      background: #2563eb;
    }

    .action-btn:focus {
      outline: 2px solid #3b82f6;
      outline-offset: 1px;
    }

    /* Alerts Panel */
    .alerts-panel {
      background: #1e293b;
      border-left: 1px solid #334155;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .alerts-header {
      padding: 16px;
      border-bottom: 1px solid #334155;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .alerts-header h2 {
      font-size: 15px;
      font-weight: 600;
      color: #f1f5f9;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .alert-count {
      background: #dc2626;
      color: white;
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 10px;
      font-weight: 600;
    }

    .alerts-list {
      flex: 1;
      overflow-y: auto;
      padding: 12px;
    }

    .alert-item {
      background: #334155;
      border-radius: 8px;
      padding: 12px;
      margin-bottom: 10px;
      border-left: 3px solid #64748b;
      cursor: pointer;
      transition: all 0.2s;
    }

    .alert-item:hover {
      background: #475569;
    }

    .alert-item.new {
      animation: slide-in-right 0.3s ease-out;
      border-left-color: #fbbf24;
      background: #4a3830;
    }

    .alert-item.critical {
      border-left-color: #dc2626;
      background: #3a1c1c;
    }

    @keyframes slide-in-right {
      from {
        opacity: 0;
        transform: translateX(20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .alert-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 8px;
    }

    .alert-type {
      font-size: 13px;
      font-weight: 600;
      color: #f1f5f9;
    }

    .alert-time {
      font-size: 11px;
      color: #94a3b8;
    }

    .alert-student {
      font-size: 12px;
      color: #cbd5e1;
      margin-bottom: 8px;
    }

    .alert-student strong {
      color: #f1f5f9;
    }

    .alert-actions {
      display: flex;
      gap: 8px;
    }

    .alert-action-btn {
      background: #475569;
      border: none;
      color: #e2e8f0;
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 11px;
      cursor: pointer;
    }

    .alert-action-btn:hover {
      background: #64748b;
    }

    .alert-action-btn.primary {
      background: #3b82f6;
    }

    .alert-action-btn.primary:hover {
      background: #2563eb;
    }

    /* Scrollbar styling */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: #1e293b;
    }

    ::-webkit-scrollbar-thumb {
      background: #475569;
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #64748b;
    }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 40px 20px;
      color: #64748b;
      font-size: 13px;
    }

    /* Design notes */
    .design-notes {
      position: fixed;
      bottom: 20px;
      right: 380px;
      background: rgba(30, 41, 59, 0.95);
      backdrop-filter: blur(8px);
      border: 1px solid #334155;
      border-radius: 8px;
      padding: 16px;
      max-width: 300px;
      font-size: 11px;
      color: #94a3b8;
      line-height: 1.6;
    }

    .design-notes h4 {
      color: #f1f5f9;
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 8px;
    }

    .design-notes ul {
      margin-left: 16px;
      margin-top: 8px;
    }

    .design-notes li {
      margin-bottom: 4px;
    }
  </style>
</head>
