# ============================================================================
# Moodle-Proctor Backend Environment Variables
# Copy this file to .env and update with your values
# ============================================================================

# Environment
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# Moodle Integration
MOODLE_BASE_URL=http://localhost:8080
MOODLE_SERVICE=moodle_mobile_app

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=24h

# AI Proctoring Service
AI_SERVICE_URL=ws://localhost:8000/proctor
AI_SERVICE_TIMEOUT=30000
AI_SERVICE_SHARED_SECRET=change-this-in-production

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
CORS_CREDENTIALS=true

# Security
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60000
REPLAY_PREVENTION_MAX_FRAMES=1000
