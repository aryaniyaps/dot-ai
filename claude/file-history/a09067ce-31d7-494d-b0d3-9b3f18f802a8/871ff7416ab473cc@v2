def parse_events_to_dataframe(events):
    """Parse Polymarket events into a flat Pandas DataFrame."""
    records = []

    for event in events:
        # Extract event-level data
        event_id = event.get('id')
        event_title = event.get('title', 'N/A')
        event_ticker = event.get('ticker', 'N/A')
        start_date = event.get('startDate', 'N/A')
        end_date = event.get('endDate', 'N/A')
        event_volume = event.get('volume', 0)

        # Extract markets (usually 1 match-winner market per event)
        markets = event.get('markets', [])

        for market in markets:
            # Parse market data
            market_id = market.get('id')
            question = market.get('question', event_title)
            outcomes_raw = market.get('outcomes', '[]')
            outcome_prices_raw = market.get('outcomePrices', '[]')
            market_volume = market.get('volume', event_volume)
            closed_time = market.get('closedTime', 'N/A')
            resolution_status = market.get('umaResolutionStatus', 'N/A')

            # Parse JSON strings
            try:
                outcomes = json.loads(outcomes_raw.replace("'", '"'))
                outcome_prices = json.loads(outcome_prices_raw.replace("'", '"'))
            except:
                outcomes = []
                outcome_prices = []

            # Create flattened record
            record = {
                'event_id': event_id,
                'event_title': event_title,
                'event_ticker': event_ticker,
                'start_date': start_date,
                'end_date': end_date,
                'market_id': market_id,
                'question': question,
                'outcomes': str(outcomes),
                'outcome_prices': str(outcome_prices),
                'outcome_prices_parsed': outcome_prices,
                'volume': float(market_volume) if market_volume else 0,
                'closed_time': closed_time,
                'resolution_status': resolution_status
            }

            records.append(record)

    return pd.DataFrame(records)

