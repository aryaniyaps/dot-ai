   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Step 3: Data Fetching Function\n",
    "\n",
    "Fetch historical T20 cricket events from Polymarket Gamma API."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def fetch_polymarket_events(tag_id=CRICKET_TAG_ID, closed=True, limit=INITIAL_LIMIT, offset=0):\n",
    "    \"\"\"\n",
    "    Fetch historical cricket T20 events from Polymarket Gamma API.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    tag_id : int\n",
    "        Polymarket tag ID for cricket (517 for T20)\n",
    "    closed : bool\n",
    "        True for historical/completed events, False for active events\n",
    "    limit : int\n",
    "        Number of events to fetch (max 1000 per request)\n",
    "    offset : int\n",
    "        Pagination offset\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    list : List of event dictionaries\n",
    "    \"\"\"\n",
    "    # Build API URL\n",
    "    params = {\n",
    "        \"tag_id\": tag_id,\n",
    "        \"closed\": \"true\" if closed else \"false\",\n",
    "        \"limit\": limit,\n",
    "        \"offset\": offset\n",
    "    }\n",
    "    \n",
    "    try:\n",
    "        response = requests.get(f\"{API_BASE_URL}/events\", params=params)\n",
    "        response.raise_for_status()\n",
    "        \n",
    "        data = response.json()\n",
    "        \n",
    "        # Courtesy delay\n",
    "        time.sleep(REQUEST_DELAY)\n",
    "        \n",
    "        return data\n",
    "    \n",
    "    except requests.exceptions.RequestException as e:\n",
    "        print(f\"❌ Error fetching data: {e}\")\n",
    "        return []\n",
    "\n",
    "# Test the function\n",
    "print(\"Testing API connection...\")\n",
    "test_events = fetch_polymarket_events(limit=5)\n",
    "print(f\"✅ Fetched {len(test_events)} test events\")\n",
    "print(f\"\\nSample event structure:\")\n",
    "if test_events:\n",
    "    print(json.dumps(test_events[0], indent=2)[:500])"
   ]
  },
