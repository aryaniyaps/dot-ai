    "def validate_outcome_prices(prices):\n",
    "    \"\"\"\n",
    "    Validate outcome prices are in valid range [0, 100] cents.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    prices : str or list\n",
    "        Outcome prices from API (string representation or list)\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    tuple : (is_valid, error_message)\n",
    "    \"\"\"\n",
    "    try:\n",
    "        # Parse string representation if needed\n",
    "        if isinstance(prices, str):\n",
    "            prices = json.loads(prices.replace(\"'\", '\"'))\n",
    "        \n",
    "        # Validate each price\n",
    "        for price in prices:\n",
    "            price_float = float(price)\n",
    "            if price_float < 0 or price_float > 1.0:  # API returns 0-1 range\n",
    "                return False, f\"Price {price_float} out of range [0, 1]\"\n",
    "        \n",
    "        return True, None\n",
    "    \n",
    "    except (ValueError, json.JSONDecodeError) as e:\n",
    "        return False, f\"Invalid price format: {e}\"\n",
    "\n",
    "\n",
    "def validate_timestamp(start_date, end_date):\n",
    "    \"\"\"\n",
    "    Validate event timestamps are chronological.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    start_date : str\n",
    "        Event start date (ISO format)\n",
    "    end_date : str\n",
    "        Event end date (ISO format)\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    tuple : (is_valid, error_message)\n",
    "    \"\"\"\n",
    "    try:\n",
    "        start = datetime.fromisoformat(start_date.replace('Z', '+00:00'))\n",
    "        end = datetime.fromisoformat(end_date.replace('Z', '+00:00'))\n",
    "        \n",
    "        if start > end:\n",
    "            return False, f\"Start date {start_date} after end date {end_date}\"\n",
    "        \n",
    "        return True, None\n",
    "    \n",
    "    except ValueError as e:\n",
    "        return False, f\"Invalid timestamp format: {e}\"\n",
    "\n",
    "\n",
    "def detect_duplicates(events, key_field='id'):\n",
    "    \"\"\"\n",
    "    Detect duplicate events by ID.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    events : list\n",
    "        List of event dictionaries\n",
    "    key_field : str\n",
    "        Field to use for duplicate detection (default: 'id')\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    tuple : (has_duplicates, duplicate_ids)\n",
    "    \"\"\"\n",
    "    seen_ids = set()\n",
    "    duplicates = []\n",
    "    \n",
    "    for event in events:\n",
    "        event_id = event.get(key_field)\n",
    "        if event_id in seen_ids:\n",
    "            duplicates.append(event_id)\n",
    "        else:\n",
    "            seen_ids.add(event_id)\n",
    "    \n",
    "    return len(duplicates) > 0, duplicates\n",
    "\n",
    "# Test validation functions\n",
    "print(\"Testing validation functions...\")\n",
    "print(f\"\\n✅ Price validation:\")\n",
    "print(f\"  - Valid prices [\\\"0\\\", \\\"1\\\"]: {validate_outcome_prices(['0', '1'])}\")\n",
    "print(f\"  - Invalid prices [\\\"0\\\", \\\"1.5\\\"]: {validate_outcome_prices(['0', '1.5'])}\")\n",
    "print(f\"\\n✅ Timestamp validation:\")\n",
    "print(f\"  - Valid order: {validate_timestamp('2024-06-01T00:00:00Z', '2024-06-02T00:00:00Z')}\")\n",
    "print(f\"  - Invalid order: {validate_timestamp('2024-06-02T00:00:00Z', '2024-06-01T00:00:00Z')}\")"
   ]
