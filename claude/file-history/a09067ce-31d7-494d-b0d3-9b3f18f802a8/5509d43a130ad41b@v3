    "def parse_events_to_dataframe(events):\n",
    "    \"\"\"\n",
    "    Parse Polymarket events into a flat Pandas DataFrame.\n",
    "    \n",
    "    Parameters:\n",
    "    -----------\n",
    "    events : list\n",
    "        List of event dictionaries from API\n",
    "    \n",
    "    Returns:\n",
    "    --------\n",
    "    pd.DataFrame : Flattened dataframe with market data\n",
    "    \"\"\"\n",
    "    records = []\n",
    "    \n",
    "    for event in events:\n",
    "        # Extract event-level data\n",
    "        event_id = event.get('id')\n",
    "        event_title = event.get('title', 'N/A')\n",
    "        event_ticker = event.get('ticker', 'N/A')\n",
    "        start_date = event.get('startDate', 'N/A')\n",
    "        end_date = event.get('endDate', 'N/A')\n",
    "        event_volume = event.get('volume', 0)\n",
    "        \n",
    "        # Extract markets (usually 1 match-winner market per event)\n",
    "        markets = event.get('markets', [])\n",
    "        \n",
    "        for market in markets:\n",
    "            # Parse market data\n",
    "            market_id = market.get('id')\n",
    "            question = market.get('question', event_title)\n",
    "            outcomes_raw = market.get('outcomes', '[]')\n",
    "            outcome_prices_raw = market.get('outcomePrices', '[]')\n",
    "            market_volume = market.get('volume', event_volume)\n",
    "            closed_time = market.get('closedTime', 'N/A')\n",
    "            resolution_status = market.get('umaResolutionStatus', 'N/A')\n",
    "            \n",
    "            # Parse JSON strings\n",
    "            try:\n",
    "                outcomes = json.loads(outcomes_raw.replace(\"'\", '\"'))\n",
    "                outcome_prices = json.loads(outcome_prices_raw.replace(\"'\", '\"'))\n",
    "            except:\n",
    "                outcomes = []\n",
    "                outcome_prices = []\n",
    "            \n",
    "            # Create flattened record\n",
    "            record = {\n",
    "                'event_id': event_id,\n",
    "                'event_title': event_title,\n",
    "                'event_ticker': event_ticker,\n",
    "                'start_date': start_date,\n",
    "                'end_date': end_date,\n",
    "                'market_id': market_id,\n",
    "                'question': question,\n",
    "                'outcomes': str(outcomes),\n",
    "                'outcome_prices': str(outcome_prices),\n",
    "                'outcome_prices_parsed': outcome_prices,\n",
    "                'volume': float(market_volume) if market_volume else 0,\n",
    "                'closed_time': closed_time,\n",
    "                'resolution_status': resolution_status\n",
    "            }\n",
    "            \n",
    "            records.append(record)\n",
    "    \n",
    "    return pd.DataFrame(records)\n",
    "\n",
