#!/usr/bin/env python3
"""
Extract __NEXT_DATA__ from Cricbuzz to get match data
"""

import requests
from bs4 import BeautifulSoup
import json
import re

session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
    'Accept': 'text/html,application/xhtml+xml',
})

match_id = "149757"
url = f"https://www.cricbuzz.com/live-cricket-scores/{match_id}/kkr-vs-lsg-15th-match-indian-premier-league-2026"

print(f"Fetching: {url}")
response = session.get(url, timeout=15)
print(f"Status: {response.status_code}")

if response.status_code != 200:
    print("❌ Failed to fetch")
    exit(1)

soup = BeautifulSoup(response.content, 'html.parser')

# Find __NEXT_DATA__ script tag
next_data_script = soup.find('script', {'id': '__NEXT_DATA__'})

if not next_data_script:
    print("❌ No __NEXT_DATA__ found")
    exit(1)

print("✅ Found __NEXT_DATA__!")

# Parse JSON
try:
    data = json.loads(next_data_script.string)
except Exception as e:
    print(f"❌ Failed to parse JSON: {e}")
    exit(1)

# Save full data
with open('/tmp/next_data_full.json', 'w') as f:
    json.dump(data, f, indent=2)
print("✅ Saved full data to /tmp/next_data_full.json")

# Explore structure
print("\n" + "=" * 100)
print("DATA STRUCTURE")
print("=" * 100)

def print_keys(obj, prefix="", depth=0, max_depth=3):
    """Recursively print keys in nested structure"""
    if depth > max_depth:
        return

    if isinstance(obj, dict):
        for key, value in obj.items():
            value_type = type(value).__name__
            if isinstance(value, (dict, list)):
                items = len(value)
                print(f"{prefix}{key}: {value_type} ({items} items)")
                if depth < max_depth:
                    print_keys(value, prefix + "  ", depth + 1)
            else:
                preview = str(value)[:100] if value is not None else "None"
                print(f"{prefix}{key}: {value_type} = {preview}")
    elif isinstance(obj, list) and len(obj) > 0:
        print(f"{prefix}[list of {len(obj)} items]")
        print_keys(obj[0], prefix + "  ", depth + 1)

print_keys(data)

# Look for match-specific data
print("\n" + "=" * 100)
print("SEARCHING FOR MATCH DATA")
print("=" * 100)

# Search for common keys
interesting_keys = ['match', 'commentary', 'score', 'ball', 'over', 'wicket', 'innings']

def find_keys(obj, parent_key="", results=None):
    """Recursively find interesting keys"""
    if results is None:
        results = []

    if isinstance(obj, dict):
        for key, value in obj.items():
            current_path = f"{parent_key}.{key}" if parent_key else key

            # Check if key is interesting
            if any(k in key.lower() for k in interesting_keys):
                results.append((current_path, type(value).__name__, len(value) if isinstance(value, (dict, list)) else None))

            # Recurse
            if isinstance(value, (dict, list)):
                find_keys(value, current_path, results)

    elif isinstance(obj, list):
        for i, item in enumerate(obj):
            current_path = f"{parent_key}[{i}]"
            if isinstance(item, (dict, list)):
                find_keys(item, current_path, results)

    return results

found = find_keys(data)
if found:
    print(f"\n✅ Found {len(found)} interesting keys:")
    for path, type_name, size in found[:20]:
        print(f"  {path}: {type_name}" + (f" ({size} items)" if size else ""))
else:
    print("\n⚠️  No obviously interesting keys found")

# Try to extract specific match data
print("\n" + "=" * 100)
print("EXTRACTING MATCH DETAILS")
print("=" * 100)

# Common Next.js data locations
props = data.get('props', {})
page_props = props.get('pageProps', {})

print(f"\nTop-level keys: {list(data.keys())}")
print(f"Props keys: {list(props.keys())}")
print(f"PageProps keys: {list(page_props.keys())}")

# Save pageProps separately
if page_props:
    with open('/tmp/next_data_pageprops.json', 'w') as f:
        json.dump(page_props, f, indent=2)
    print("\n✅ Saved pageProps to /tmp/next_data_pageprops.json")

print("\n" + "=" * 100)
print("✅ Complete!")
print("=" * 100)
