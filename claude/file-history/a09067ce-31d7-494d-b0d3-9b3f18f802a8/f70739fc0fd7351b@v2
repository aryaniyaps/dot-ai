#!/usr/bin/env python3
"""
Test Cricbuzz API endpoints
"""

import requests
import json

session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
    'Accept': 'application/json, text/plain, */*',
    'Referer': 'https://www.cricbuzz.com/',
})

# Known Cricbuzz API endpoints to test
match_id = "149757"

api_endpoints = [
    f"https://www.cricbuzz.com/api/match/{match_id}",
    f"https://www.cricbuzz.com/api/match/{match_id}/commentary",
    f"https://www.cricbuzz.com/api/matches/{match_id}",
    f"https://www.cricbuzz.com/api/matches/{match_id}/commentary",
    f"https://www.cricbuzz.com/api/cricket-match/{match_id}",
    f"https://www.cricbuzz.com/api/cricket-match/{match_id}/commentary",
    f"https://www.cricbuzz.com/live-cricket-scores/api/{match_id}",
    f"https://www.cricbuzz.com/api/live-cricket-scores/{match_id}",
    f"https://cricbuzz.com/api/match/{match_id}/commentary",
    f"https://cricbuzz.com/match/{match_id}/commentary",
]

print("=" * 100)
print("🔍 Testing Cricbuzz API Endpoints")
print("=" * 100)

for url in api_endpoints:
    try:
        print(f"\n📡 Testing: {url}")
        response = session.get(url, timeout=10)
        print(f"   Status: {response.status_code}")

        if response.status_code == 200:
            print(f"   ✅ SUCCESS!")
            try:
                data = response.json()
                print(f"   Data type: {type(data)}")
                if isinstance(data, dict):
                    print(f"   Keys: {list(data.keys())[:10]}")
                elif isinstance(data, list):
                    print(f"   List length: {len(data)}")
                    if len(data) > 0:
                        print(f"   First item keys: {list(data[0].keys())[:10] if isinstance(data[0], dict) else 'N/A'}")

                # Save successful response
                filename = f"/tmp/cricbuzz_api_{url.split('/')[-1]}.json"
                with open(filename, 'w') as f:
                    json.dump(data, f, indent=2)
                print(f"   ✅ Saved to: {filename}")

            except Exception as e:
                print(f"   Response (first 500 chars): {response.text[:500]}")

        elif response.status_code == 404:
            print(f"   ⚠️  Not found (404)")

        elif response.status_code == 403:
            print(f"   ❌ Forbidden (403)")

    except Exception as e:
        print(f"   ❌ Error: {e}")

print("\n" + "=" * 100)
print("✅ API Testing Complete")
print("=" * 100)
