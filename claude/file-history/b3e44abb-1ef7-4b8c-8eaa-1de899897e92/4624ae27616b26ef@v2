### Phase 2: Moodle Quiz API Integration (Days 3-4)

**2.1 Extend moodle.service.ts for Quiz API**

Add to `backend/src/modules/auth/moodle.service.ts`:

```typescript
interface MoodleQuiz {
  id: number;
  course: number;
  coursename: string;
  name: string;
  intro: string;
  timeopen: number;
  timeclose: number;
  timelimit: number;
}

interface MoodleQuizQuestion {
  id: number;
  slot: number;
  type: string;
  question: {
    id: number;
    name: string;
    questiontext: string;
    defaultmark: number;
  };
}

interface MoodleQuizAttempt {
  id: number;
  quiz: number;
  attempt: number;
  state: 'inprogress' | 'finished' | 'abandoned';
  timestart: number;
  timefinish: number;
  timemodified: number;
}

/**
 * Get quiz by ID
 */
async getQuizById(token: string, quizId: number): Promise<MoodleQuiz> {
  const params = new URLSearchParams({
    wstoken: token,
    wsfunction: 'mod_quiz_get_quizzes_by_ids',
    moodlewsrestformat: 'json',
    'quizids[0]': quizId.toString()
  });

  const response = await axios.get(
    `${this.baseUrl}/webservice/rest/server.php`,
    { params }
  );

  if (response.data.quizzes && response.data.quizzes.length > 0) {
    return response.data.quizzes[0];
  }

  throw new MoodleError('Quiz not found');
}

/**
 * Get quiz questions for an attempt
 */
async getQuizQuestions(
  token: string,
  quizId: number,
  attemptId: number
): Promise<MoodleQuizQuestion[]> {
  const params = new URLSearchParams({
    wstoken: token,
    wsfunction: 'mod_quiz_get_attempt_data',
    moodlewsrestformat: 'json',
    attemptid: attemptId.toString(),
    page: '0'
  });

  const response = await axios.get(
    `${this.baseUrl}/webservice/rest/server.php`,
    { params }
  );

  return response.data.questions || [];
}

/**
 * Start new quiz attempt
 */
async startQuizAttempt(
  token: string,
  quizId: number,
  userid: number
): Promise<MoodleQuizAttempt> {
  const params = new URLSearchParams({
    wstoken: token,
    wsfunction: 'mod_quiz_start_attempt',
    moodlewsrestformat: 'json',
    quizid: quizId.toString(),
    userid: userid.toString(),
    prefetch: '1' // Preload questions
  });

  const response = await axios.post(
    `${this.baseUrl}/webservice/rest/server.php`,
    params
  );

  return response.data.attempt || response.data;
}

/**
 * Submit question response
 */
async submitQuestionResponse(
  token: string,
  attemptId: number,
  slot: number,
  response: Record<string, any>
): Promise<void> {
  const params = new URLSearchParams({
    wstoken: token,
    wsfunction: 'mod_quiz_process_attempt',
    moodlewsrestformat: 'json',
    attemptid: attemptId.toString(),
    data: JSON.stringify([{ slot, response }])
  });

  await axios.post(
    `${this.baseUrl}/webservice/rest/server.php`,
    params
  );
}

/**
 * Finish quiz attempt
 */
async finishQuizAttempt(token: string, attemptId: number): Promise<void> {
  const params = new URLSearchParams({
    wstoken: token,
    wsfunction: 'mod_quiz_process_attempt',
    moodlewsrestformat: 'json',
    attemptid: attemptId.toString(),
    finishattempt: '1'
  });

  await axios.post(
    `${this.baseUrl}/webservice/rest/server.php`,
    params
  );
}
```

**2.2 Create Quiz proxy endpoint**

Create `backend/src/modules/quiz/quiz.routes.ts`:

```typescript
import { FastifyInstance } from 'fastify';
import moodleService from '../auth/moodle.service';
import { authMiddleware } from '../../middleware/auth.middleware';

export async function quizRoutes(fastify: FastifyInstance) {
  // Get quiz details
  fastify.get('/api/quiz/:quizId', {
    preHandler: [authMiddleware]
  }, async (request, reply) => {
    const { quizId } = request.params as { quizId: string };
    const user = (request as any).user;

    try {
      const quiz = await moodleService.getQuizById(
        user.moodleToken,
        parseInt(quizId, 10)
      );

      return {
        success: true,
        data: quiz
      };
    } catch (error) {
      logger.error('Failed to fetch quiz:', error);
      return reply.code(500).send({
        success: false,
        error: 'Failed to load quiz'
      });
    }
  });

  // Start quiz attempt
  fastify.post('/api/quiz/:quizId/start', {
    preHandler: [authMiddleware]
  }, async (request, reply) => {
    const { quizId } = request.params as { quizId: string };
    const user = (request as any).user;

    try {
      const attempt = await moodleService.startQuizAttempt(
        user.moodleToken,
        parseInt(quizId, 10),
        user.moodleUserId
      );

      return {
        success: true,
        data: attempt
      };
    } catch (error) {
      logger.error('Failed to start quiz:', error);
      return reply.code(500).send({
        success: false,
        error: 'Failed to start quiz'
      });
    }
  });

  // Get quiz questions
  fastify.get('/api/quiz/attempt/:attemptId/questions', {
    preHandler: [authMiddleware]
  }, async (request, reply) => {
    const { attemptId } = request.params as { attemptId: string };
    const { quizId } = request.query as { quizId: string };
    const user = (request as any).user;

    try {
      const questions = await moodleService.getQuizQuestions(
        user.moodleToken,
        parseInt(quizId, 10),
        parseInt(attemptId, 10)
      );

      return {
        success: true,
        data: questions
      };
    } catch (error) {
      logger.error('Failed to fetch questions:', error);
      return reply.code(500).send({
        success: false,
        error: 'Failed to load questions'
      });
    }
  });

  // Submit answer
  fastify.post('/api/quiz/attempt/:attemptId/submit', {
    preHandler: [authMiddleware]
  }, async (request, reply) => {
    const { attemptId } = request.params as { attemptId: string };
    const { slot, response } = request.body as { slot: number; response: any };
    const user = (request as any).user;

    try {
      await moodleService.submitQuestionResponse(
        user.moodleToken,
        parseInt(attemptId, 10),
        slot,
        response
      );

      return { success: true };
    } catch (error) {
      logger.error('Failed to submit answer:', error);
      return reply.code(500).send({
        success: false,
        error: 'Failed to submit answer'
      });
    }
  });

  // Finish quiz
  fastify.post('/api/quiz/attempt/:attemptId/finish', {
    preHandler: [authMiddleware]
  }, async (request, reply) => {
    const { attemptId } = request.params as { attemptId: string };
    const user = (request as any).user;

    try {
      await moodleService.finishQuizAttempt(
        user.moodleToken,
        parseInt(attemptId, 10)
      );

      return { success: true };
    } catch (error) {
      logger.error('Failed to finish quiz:', error);
      return reply.code(500).send({
        success: false,
        error: 'Failed to finish quiz'
      });
