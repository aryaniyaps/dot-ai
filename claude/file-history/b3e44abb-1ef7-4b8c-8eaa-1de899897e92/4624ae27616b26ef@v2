**1.3 Create LTI launch endpoint**

Create `backend/src/modules/lti/lti.routes.ts`:

```typescript
import { FastifyInstance } from 'fastify';
import lti, { moodlePlatform } from './lti.service';
import logger from '../../config/logger';

export async function ltiRoutes(fastify: FastifyInstance) {
  // LTI launch endpoint (receives POST from Moodle)
  fastify.post('/lti/launch', {
    config: { public: true } // No auth required — LTI signature validates
  }, async (request, reply) => {
    try {
      const body = request.body as any;

      logger.info('LTI launch received', {
        context_id: body.context_id,
        context_label: body.context_label,
        resource_link_id: body.resource_link_id,
        user_id: body.user_id,
        roles: body.roles
      });

      // Validate OAuth 1.0 signature via ltijs
      const valid = await lti.validateLaunch(body);
      if (!valid) {
        return reply.code(403).send({
          success: false,
          error: 'Invalid LTI signature'
        });
      }

      // Extract LTI parameters
      const launchData = {
        contextId: body.context_id,
        contextLabel: body.context_label,
        contextTitle: body.context_title,
        resourceId: body.resource_link_id,
        resourceTitle: body.resource_link_title,
        userId: body.user_id,
        userUsername: body.ext_user_username || body.lis_person_sourcedid,
        userFirstname: body.lis_person_name_given,
        userLastname: body.lis_person_name_family,
        userFullname: body.lis_person_name_full,
        userEmail: body.lis_person_contact_email_primary,
        roles: body.roles, // "Learner", "Instructor", "TeachingAssistant", etc.
        outcomeServiceUrl: body.lis_outcome_service_url,
        outcomeResultId: body.lis_result_sourcedid,
        consumerKey: body.oauth_consumer_key,
        oauthTimestamp: body.oauth_timestamp,
        oauthNonce: body.oauth_nonce
      };

      // Route based on role
      const isInstructor = launchData.roles && launchData.roles.includes('Instructor');

      if (isInstructor) {
        // Instructor → redirect to teacher dashboard or show room info
        return handleInstructorLaunch(launchData, reply);
      } else {
        // Student → join proctoring room
        return handleStudentLaunch(launchData, reply);
      }

    } catch (error) {
      logger.error('LTI launch error:', error);
      return reply.code(500).send({
        success: false,
        error: 'LTI launch failed'
      });
    }
  });

  // LTI configuration endpoint (for Moodle tool registration)
  fastify.get('/lti/config', {
    config: { public: true }
  }, async (request, reply) => {
    const baseUrl = process.env.LTI_APP_URL || 'http://localhost:5000';

    return reply.type('application/xml').send(`
      <?xml version="1.0" encoding="UTF-8"?>
      <cartridge_basiclti_link xmlns="http://www.imsglobal.org/xsd/imslticc_v1p0"
                              xmlns:blti="http://www.imsglobal.org/xsd/imsbasiclti_v1p0"
                              xmlns:lticm="http://www.imsglobal.org/xsd/imslticm_v1p0"
                              xmlns:lticp="http://www.imsglobal.org/xsd/imslticp_v1p0"
                              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                              xsi:schemaLocation="http://www.imsglobal.org/xsd/imslticc_v1p0 http://www.imsglobal.org/xsd/ltic/ltic_v1p0.xsd
                                                  http://www.imsglobal.org/xsd/imsbasiclti_v1p0 http://www.imsglobal.org/xsd/imsbasiclti_v1p0p3.xsd
                                                  http://www.imsglobal.org/xsd/imslticm_v1p0 http://www.imsglobal.org/xsd/imslticm_v1p0.xsd
                                                  http://www.imsglobal.org/xsd/imslticp_v1p0 http://www.imsglobal.org/xsd/imslticp_v1p0.xsd">
        <blti:title>Moodle Proctoring Tool</blti:title>
        <blti:description>AI-powered proctoring for secure online exams</blti:description>
        <blti:icon></blti:icon>
        <blti:launch_url>${baseUrl}/lti/launch</blti:launch_url>
        <blti:extensions platform="moodle">
          <lticm:property name="privacy_level">public</lticm:property>
          <lticm:property name="domain">${baseUrl}</lticm:property>
        </blti:extensions>
        <cartridge_bundle identifierref="BLTI001_Bundle"/>
        <cartridge_icon identifierref="BLTI001_Icon"/>
      </cartridge_basiclti_link>
    `);
  });
}

async function handleInstructorLaunch(launchData: any, reply: FastifyReply) {
  // Instructors see room info or redirect to teacher dashboard
  const roomCode = await getOrCreateRoomForContext(launchData);

  // Redirect to teacher dashboard with room selected
  return reply.redirect(`/dashboard?room=${roomCode}`);
}

async function handleStudentLaunch(launchData: any, reply: FastifyReply) {
  // Students join the proctoring room
  const roomCode = await getOrCreateRoomForContext(launchData);

  // Generate session token
  const token = jwt.sign({
    userId: launchData.userId,
    contextId: launchData.contextId,
    resourceId: launchData.resourceId,
    role: 'student',
    ltiLaunch: true
  }, process.env.JWT_SECRET || 'dev-secret');

  // Redirect to desktop app launch page
  // Desktop app should register custom protocol: proctor://launch?token=...
  return reply.send({
    success: true,
    action: 'launch_desktop_app',
    data: {
      roomCode,
      token,
      launchUrl: `proctor://launch?room=${roomCode}&token=${token}`
    }
  });
}

async function getOrCreateRoomForContext(launchData: any): Promise<string> {
  // Use context_id + resource_link_id as unique identifier
  const roomKey = `${launchData.contextId}_${launchData.resourceId}`;

  // Check if room exists
  const existingRoom = await fastify.pg.query(
    'SELECT room_code FROM proctoring_rooms WHERE lti_context_key = $1',
    [roomKey]
  );

  if (existingRoom.rows.length > 0) {
    return existingRoom.rows[0].room_code;
  }

  // Create new room for this LTI context
  // TODO: Need exam_id — how do we map LTI resource to exam?
  // For now, use default or create on first access
  const newRoom = await roomService.createRoom({
    examId: 1, // Default exam — NEEDS FIX
    createdBy: launchData.userId || 0,
    ltiContextKey: roomKey,
    ltiContextLabel: launchData.contextLabel || launchData.contextTitle,
    ltiResourceId: launchData.resourceId
  });

  return newRoom.room_code;
}
```

