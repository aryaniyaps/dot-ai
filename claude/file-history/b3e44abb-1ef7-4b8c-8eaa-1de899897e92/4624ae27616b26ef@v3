function renderQuestions(questions) {
  const container = document.getElementById('quiz-questions');
  container.innerHTML = '';

  questions.forEach((q, index) => {
    const questionDiv = document.createElement('div');
    questionDiv.className = 'question-item';
    questionDiv.dataset.slot = q.slot;

    const questionText = q.question.questiontext;
    const questionType = q.type; // 'multichoice', 'essay', 'truefalse', etc.

    // Render based on question type
    let inputHtml = '';

    if (questionType === 'multichoice' || questionType === 'multichoice_single') {
      // Multiple choice (radio buttons)
      inputHtml = renderMultipleChoice(q);
    } else if (questionType === 'essay') {
      // Essay question (textarea)
      inputHtml = `
        <textarea
          class="answer-textarea"
          data-slot="${q.slot}"
          placeholder="Enter your answer here..."
        ></textarea>
      `;
    } else {
      // Default: textarea for unknown types
      inputHtml = `
        <textarea
          class="answer-textarea"
          data-slot="${q.slot}"
          placeholder="Enter your answer here..."
        ></textarea>
      `;
    }

    questionDiv.innerHTML = `
      <h3>Question ${index + 1}</h3>
      <div class="question-text">${questionText}</div>
      <div class="question-input" data-slot="${q.slot}">
        ${inputHtml}
      </div>
    `;

    container.appendChild(questionDiv);
  });
}

/**
 * Render multiple choice question with radio buttons
 */
function renderMultipleChoice(question) {
  // NOTE: Moodle Quiz API structure may vary
  // Adjust based on actual API response structure
  const answers = question.answers || [];

  if (answers.length === 0) {
    return '<p class="error">No answers available for this question</p>';
  }

  let html = '<div class="multiple-choice-options">';
  answers.forEach((answer, index) => {
    const answerText = answer.text || answer.answer;
    const answerValue = answer.value || index;

    html += `
      <label class="multiple-choice-option">
        <input
          type="radio"
          name="question-${question.slot}"
          value="${answerValue}"
          data-slot="${question.slot}"
          data-answer="${answerValue}"
        >
        <span>${answerText}</span>
      </label>
    `;
  });
  html += '</div>';

  return html;
}

async function submitQuiz() {
  if (!confirm('Are you sure you want to submit your quiz?')) {
    return;
  }

  try {
    setExamStatus('Submitting answers...', 'info');

    // Collect all answers (both textareas and radio buttons)
    const answers = [];

    // Get textarea answers (essay questions)
    const textareas = document.querySelectorAll('.answer-textarea');
    textareas.forEach(textarea => {
      const slot = parseInt(textarea.dataset.slot, 10);
      answers.push({
        slot: slot,
        answer: { answer: textarea.value }
      });
    });

    // Get radio button answers (multiple choice)
    const radioGroups = document.querySelectorAll('input[type="radio"]:checked');
    radioGroups.forEach(radio => {
      const slot = parseInt(radio.dataset.slot, 10);
      const answerValue = radio.dataset.answer;
      answers.push({
        slot: slot,
        answer: { answer: answerValue }
      });
    });

    // Submit all answers
    for (const answerData of answers) {
      await submitAnswer(currentAttempt.id, answerData.slot, answerData.answer, session.token);
