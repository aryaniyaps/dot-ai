# ============================================================================
# Moodle-Proctor Backend Environment Variables
# Development Configuration
# ============================================================================

# Environment
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database (PostgreSQL)
# Note: Port 5433 is mapped from docker-compose
DATABASE_URL=postgresql://proctor_user:proctor_pass@localhost:5433/moodle_proctor

# LTI Configuration
# Consumer key and secret must match what's configured in Moodle
LTI_CONSUMER_KEY=moodle
LTI_CONSUMER_SECRET=secret
# Set to 'true' to disable OAuth signature validation (ONLY for development/testing)
LTI_DISABLE_SIGNATURE_VALIDATION=false

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# Moodle Integration
MOODLE_BASE_URL=http://localhost:8080
MOODLE_SERVICE=moodle_mobile_app

# JWT Configuration
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=24h

# AI Proctoring Service
AI_SERVICE_URL=ws://localhost:8000/proctor
AI_SERVICE_TIMEOUT=30000
AI_SERVICE_SHARED_SECRET=default-secret

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
CORS_CREDENTIALS=true

# Security
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60000
REPLAY_PREVENTION_MAX_FRAMES=1000
